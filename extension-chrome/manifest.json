{
    "manifest_version": 3,
    "name": "MiniMe Activity Tracker",
    "version": "1.1.0",
    "description": "Privacy-first web activity tracking for mindful productivity",
    "permissions": [
        "tabs",
        "storage",
        "alarms",
        "webNavigation",
        "contextMenus",
        "nativeMessaging"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "https://api.tryminime.com/*",
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content/code-block-extractor.js",
                "content/content-extractor.js",
                "content/activity-detector.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "options_ui": {
        "page": "options/settings.html",
        "open_in_tab": true
    },
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icon-16.png",
            "48": "assets/icon-48.png",
            "128": "assets/icon-128.png"
        }
    },
    "icons": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "homepage_url": "https://tryminime.com",
    "browser_specific_settings": {
        "gecko": {
            "id": "minime@tryminime.com",
            "strict_min_version": "109.0"
        }
    }
}