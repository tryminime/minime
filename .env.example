# Environment Configuration
ENVIRONMENT=development

# Database URLs
DATABASE_URL=postgresql://minime:minime_dev_password@localhost:5432/minime
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=minime_dev_password
REDIS_URL=redis://:minime_dev_password@localhost:6379/0
QDRANT_URL=http://localhost:6333

# JWT Configuration
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=100

# ============================================================================
# AI & LLM Configuration
# ============================================================================

# Choose your LLM backend: "ollama" (local, free) or "openai" (cloud, paid)
USE_OLLAMA=true

# Ollama Configuration (Local LLM - FREE)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Run: ollama serve
# Models: ollama pull llama2 (or llama3, mistral, codellama, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# OpenAI Configuration (Cloud LLM - PAID)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_ORG_ID=

# Anthropic Claude Configuration (Alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# AI Settings
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7
AI_CONTEXT_WINDOW=4096

# Email Configuration (for verification, password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@minime.ai

# Feature Flags
ENABLE_RAG_ASSISTANT=true
ENABLE_BURNOUT_DETECTION=false
ENABLE_ENTERPRISE_FEATURES=false

# Logging
LOG_LEVEL=INFO
