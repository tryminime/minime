{
    "manifest_version": 2,
    "name": "MiniMe - Activity Intelligence",
    "version": "0.1.0",
    "description": "Capture your activity. Understand your time. Privacy-first web tracking.",
    "permissions": [
        "tabs",
        "storage",
        "alarms",
        "webNavigation",
        "contextMenus",
        "http://localhost:8000/*",
        "https://api.tryminime.com/*"
    ],
    "options_ui": {
        "page": "options/settings.html",
        "open_in_tab": true
    },
    "background": {
        "scripts": [
            "background/service-worker.js"
        ]
    },
    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_title": "MiniMe - Activity Intelligence",
        "default_icon": {
            "16": "assets/icon-16.png",
            "48": "assets/icon-48.png",
            "128": "assets/icon-128.png"
        }
    },
    "icons": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "minime@tryminime.com",
            "strict_min_version": "88.0"
        }
    },
    "homepage_url": "https://tryminime.com"
}